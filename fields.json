{
  "_guide_intro": {
    "label": "── Guide d'installation ──────────────────",
    "type": "label",
    "value": "1. Crée un compte sur last.fm (gratuit)\n2. Va sur last.fm/api → Create an API account\n3. Copie ta clé API et entre-la ci-dessous\n4. Entre ton pseudo Last.fm\n5. Lance une musique — le widget apparaît automatiquement !"
  },
  "_guide_api": {
    "label": "Où trouver ta clé API Last.fm ?",
    "type": "label",
    "value": "Lien direct : https://www.last.fm/api/account/create\nRubrique : \"API key\" (champ sur la page)"
  },

  "_sep_config": {
    "label": "── Configuration ─────────────────────────",
    "type": "label",
    "value": ""
  },
  "username": {
    "label": "Pseudo Last.fm",
    "type": "text",
    "value": ""
  },
  "apiKey": {
    "label": "Clé API Last.fm",
    "type": "text",
    "value": ""
  },

  "_sep_display": {
    "label": "── Apparence ─────────────────────────────",
    "type": "label",
    "value": ""
  },
  "displayMode": {
    "label": "Mode d'affichage",
    "type": "dropdown",
    "value": "default",
    "options": {
      "default": "Complet (par défaut)",
      "minimal": "Minimaliste"
    }
  },
  "accentColor": {
    "label": "Couleur accent (artiste, barres, progression)",
    "type": "colorpicker",
    "value": "#1db954"
  },
  "scale": {
    "label": "Taille du widget (échelle)",
    "type": "slider",
    "value": 1,
    "min": 0.3,
    "max": 2.0,
    "steps": 0.05
  },
  "emoteUrl": {
    "label": "URL de l'emote (image personnalisée, optionnel)",
    "type": "text",
    "value": ""
  },

  "_sep_options": {
    "label": "── Options (mode Complet uniquement) ─────",
    "type": "label",
    "value": ""
  },
  "showAlbum": {
    "label": "Afficher le nom de l'album",
    "type": "checkbox",
    "value": true
  },
  "showTimer": {
    "label": "Afficher le timer",
    "type": "checkbox",
    "value": true
  },
  "showProgress": {
    "label": "Afficher la barre de progression",
    "type": "checkbox",
    "value": true
  },

  "_sep_react": {
    "label": "── Réactions Chat ────────────────────────",
    "type": "label",
    "value": "Quand un viewer tape la commande dans le chat, un emote apparaît sur le widget et monte en flottant."
  },
  "reactEnabled": {
    "label": "Activer les réactions chat",
    "type": "checkbox",
    "value": true
  },
  "reactCommand": {
